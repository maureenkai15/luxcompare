# ─────────────────────────────────────────────
# LuxCompare AI — Backend environment variables
# Copy to .env and edit as needed
# ─────────────────────────────────────────────

# FX cache TTL in seconds (default 900 = 15 min)
FX_CACHE_TTL_SECONDS=900

# Path to optional CSV price overrides
# CSV columns: product_id,country,currency,price
PRICE_CSV_PATH=data/prices_override.csv

# PostgreSQL connection (optional — MVP uses in-memory data by default)
# DATABASE_URL=postgresql://user:password@localhost:5432/luxcompare
